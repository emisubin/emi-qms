{
  "Authentication": {
    "Mode": "Dev"
  },
  "DevAuthentication": {
    "Enabled": true
  },
  "AdminUserSwitch": {
    "Enabled": false
  },
  "Database": {
    "ApplyMigrationsOnStartup": true
  },
  "DevelopmentData": {
    "SeedEnabled": true
  },
  "Notifications": {
    "Dispatch": {
      "Enabled": false
    },
    "DailyDigest": {
      "Enabled": false
    },
    "Teams": {
      "Enabled": false,
      "DryRun": true,
      "PayloadMode": "AdaptiveCardRoot"
    },
    "Mail": {
      "Enabled": false,
      "DryRun": true,
      "Provider": "DryRun",
      "SenderDisplayName": "EMI 프로젝트 통합관리시스템 알림",
      "Smtp": {
        "Host": "",
        "Port": 587,
        "Security": "StartTls",
        "Username": "",
        "Password": "",
        "TimeoutSeconds": 30
      }
    },
    "Graph": {
      "AuthorityHost": "https://login.microsoftonline.com",
      "BaseUrl": "https://graph.microsoft.com/v1.0",
      "Scope": "https://graph.microsoft.com/.default"
    }
  }
}
